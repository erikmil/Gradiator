{
  "expo": {
    "name": "Gradiator",
    "slug": "ConvertClimb",
    "description": "Convert and compare climbing grades across international grading systems",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/splash-icon-dark.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.gradiator.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": {
        "light": "./assets/icons/ios-light.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#1A18BA"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.gradiator.app"
    },
    "web": {
      "favicon": "./assets/app-logo.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/coolvetica_rg.ttf"
          ]
        }
      ]
    ],
    "owner": "erikmil",
    "extra": {
      "eas": {
        "projectId": "fb256c4f-e6df-45f8-bc96-c09cfca103b3"
      }
    }
  }
}
